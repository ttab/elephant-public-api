        },
        "type": "object"
      },
      "ttab.distribution.LabelExpression": {
        "properties": {
          "expression": {
            "description": "Expression is a newsdoc value extraction expression.",
            "type": "string"
          },
          "template": {
            "description": "Template is the template that turns the extracted values into a label.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListActiveSchemasRequest": {
        "type": "object"
      },
      "ttab.distribution.ListActiveSchemasResponse": {
        "properties": {
          "schemas": {
            "description": "Schemas without the spec populated",
