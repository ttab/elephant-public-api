  "tags": [
    {
      "name": "Configuration"
    },
    {
      "name": "Content"
    },
    {
      "description": "Archive exposes the offloaded eventlog history and document versions for bulk export - e.g. building or rebuilding a search index over the full content set. Bodies are delivered as presigned URLs that the consumer fetches directly from object storage; the service only brokers the catalog and mints the URLs. Object keys and the presigning mechanism are internal: consumers address content by identity (uuid, version, chunk_id), never by storage key.",
      "name": "Archive"
    }
  ]
