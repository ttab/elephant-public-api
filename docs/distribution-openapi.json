{
  "components": {
    "schemas": {
      "newsdoc.Block": {
        "description": "Block is the building block for data embedded in documents. It is used for both content, links and metadata. Blocks have can be nested, but that's nothing to strive for, keep it simple.",
        "properties": {
          "content": {
            "description": "Content is used to embed content blocks.",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "contenttype": {
            "description": "ContentType is used to describe the content type of the block/linked entity if it differs from the type of the block.",
            "type": "string"
          },
          "data": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Data contains block data.",
            "type": "object"
          },
          "id": {
            "description": "ID is the block ID,",
            "type": "string"
          },
          "links": {
            "description": "Links are used to link to other resources and documents.",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "meta": {
            "description": "Meta is used to embed metadata",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "name": {
            "description": "Name is a name for the block. An alternative to \"rel\" when relationship is a term that doesn't fit.",
            "type": "string"
          },
          "rel": {
            "description": "Rel describes the relationship to the document/parent entity.",
            "type": "string"
          },
          "role": {
            "description": "Role is used either as an alternative to rel, or for nuancing the relationship.",
            "type": "string"
          },
          "sensitivity": {
            "description": "Sensitivity can be use to communicate how the information in a block can be handled. It could f.ex. be set to \"internal\", to show that it contains information that must be removed or transformed before publishing.",
            "type": "string"
          },
          "title": {
            "description": "Title is the title/headline of the block, typically used in the presentation of the block.",
            "type": "string"
          },
          "type": {
            "description": "Type is the type of the block",
            "type": "string"
          },
          "uri": {
            "description": "URI is used to reference another entity in a document.",
            "type": "string"
          },
          "url": {
            "description": "URL is a browseable URL for the the block.",
            "type": "string"
          },
          "uuid": {
            "description": "UUID is used to reference another Document in a block.",
            "type": "string"
          },
          "value": {
            "description": "Value is a value for the block. Useful when we want to store a primitive value.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "newsdoc.Document": {
        "description": "Document is a NewsDoc document.",
        "properties": {
          "content": {
            "description": "Content is the content of the document, this is essentially what gets rendered on the page when you view a document.",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "language": {
            "description": "Language is the language used in the document as an IETF language tag. F.ex. \"en\", \"en-UK\", \"es\", or \"sv-SE\".",
            "type": "string"
          },
          "links": {
            "description": "Links are links to other resources and entities. This could be links to topics, categories and subjects for the document, or credited authors.",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "meta": {
            "description": "Meta is the metadata for a document, this could be things like teasers, open graph data, newsvalues.",
            "items": {
              "$ref": "#/components/schemas/newsdoc.Block"
            },
            "type": "array"
          },
          "title": {
            "description": "Title is the title of the document, can be used as the document name, or the headline when the document is displayed.",
            "type": "string"
          },
          "type": {
            "description": "Type is the content type of the document.",
            "type": "string"
          },
          "uri": {
            "description": "URI identifies the document (in a more human-readable way than the UUID).",
            "type": "string"
          },
          "url": {
            "description": "URL is the browseable location of the document (if any).",
            "type": "string"
          },
          "uuid": {
            "description": "UUID is a unique ID for the document, this can for example be a random v4 UUID, or a URI-derived v5 UUID.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ActivateConfigGenerationRequest": {
        "properties": {
          "id": {
            "description": "ID of the generation to activate.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ActivateConfigGenerationResponse": {
        "properties": {
          "generation": {
            "$ref": "#/components/schemas/ttab.distribution.ConfigGeneration"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ArchiveChunk": {
        "properties": {
          "chunk_id": {
            "description": "ChunkID is the sequential chunk identifier.",
            "type": "integer"
          },
          "events_url": {
            "description": "EventsURL is a presigned GET URL for the chunk event zip.",
            "type": "string"
          },
          "first_event_at": {
            "description": "FirstEventAt is the timestamp of the first event, RFC3339.",
            "type": "string"
          },
          "first_event_id": {
            "description": "FirstEventID is the first eventlog ID in the chunk.",
            "type": "integer"
          },
          "last_event_at": {
            "description": "LastEventAt is the timestamp of the last event, RFC3339.",
            "type": "string"
          },
          "last_event_id": {
            "description": "LastEventID is the last eventlog ID in the chunk.",
            "type": "integer"
          },
          "manifest_hash": {
            "description": "ManifestHash is the hex-encoded sha256 of the canonical manifest.",
            "type": "string"
          },
          "manifest_url": {
            "description": "ManifestURL is a presigned GET URL for the signed chunk manifest.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ArchivedDocument": {
        "properties": {
          "content_url": {
            "description": "ContentURL is a presigned GET URL for the canonical document JSON.",
            "type": "string"
          },
          "hash": {
            "description": "Hash is the hex-encoded sha256 of the canonical document body, for a pre-download integrity check. The document object's own signature (the authoritative verification anchor) is delivered with the object.",
            "type": "string"
          },
          "uuid": {
            "description": "UUID of the document.",
            "type": "string"
          },
          "version": {
            "description": "Version is the latest archived version, or -1 if the document has been tombstoned (in which case there is no content URL).",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ConfigGeneration": {
        "properties": {
          "activated_at": {
            "description": "ActivatedAt is the time the generation was last activated, RFC3339, or empty if it has never been activated.",
            "type": "string"
          },
          "created_at": {
            "description": "CreatedAt is the time of registration, RFC3339.",
            "type": "string"
          },
          "description": {
            "description": "Description is an optional human-readable tag.",
            "type": "string"
          },
          "id": {
            "description": "ID is assigned by the server on registration.",
            "type": "integer"
          },
          "schemas": {
            "description": "Schemas in the generation.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ConfigGenerationSchema"
            },
            "type": "array"
          },
          "types": {
            "description": "Types configured in the generation.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ConfigGenerationType"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ConfigGenerationSchema": {
        "description": "ConfigGenerationSchema references a schema version included in a generation. Spec is optional when the version is already stored; it is required when registering a new (name, version) pair.",
        "properties": {
          "name": {
            "type": "string"
          },
          "spec": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ConfigGenerationType": {
        "description": "ConfigGenerationType configures a document type within a generation.",
        "properties": {
          "configuration": {
            "$ref": "#/components/schemas/ttab.distribution.TypeConfiguration"
          },
          "type": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.DocumentEvent": {
        "properties": {
          "doc_uuid": {
            "description": "DocUUID is the UUID of the affected document.",
            "type": "string"
          },
          "event_type": {
            "description": "EventType is either \"published\" or \"unpublished\".",
            "type": "string"
          },
          "id": {
            "description": "ID of the event.",
            "type": "integer"
          },
          "version": {
            "description": "Version that was published (if this was a publish event).",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.DocumentItem": {
        "properties": {
          "document": {
            "$ref": "#/components/schemas/newsdoc.Document"
          },
          "event": {
            "$ref": "#/components/schemas/ttab.distribution.DocumentEvent"
          },
          "subset": {
            "description": "Subset is the extracted subset of the document.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ExtractedValues"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ExtractedValue": {
        "properties": {
          "annotation": {
            "description": "Annotations can be used to differentiate between different extracted values.",
            "type": "string"
          },
          "block": {
            "$ref": "#/components/schemas/newsdoc.Block"
          },
          "role": {
            "description": "Role can be used to differentiate between different extracted values.",
            "type": "string"
          },
          "value": {
            "description": "Value is used for extracted attributes and data values.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ExtractedValues": {
        "properties": {
          "extractor": {
            "description": "Extractor index for the the extractor that produced the values.",
            "type": "integer"
          },
          "values": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ttab.distribution.ExtractedValue"
            },
            "description": "Values that were extracted.",
            "type": "object"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetActiveConfigGenerationRequest": {
        "properties": {
          "known_id": {
            "description": "KnownId is the generation ID the client already has; the call returns immediately when the active generation differs. Optional.",
            "type": "integer"
          },
          "only_changed": {
            "description": "OnlyChanged returns an empty response (with Unchanged=true) if the active generation matches KnownId.",
            "type": "boolean"
          },
          "wait_seconds": {
            "description": "WaitSeconds is the maximum number of seconds to wait for the active generation to differ from KnownId. Defaults to 10. Optional.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetActiveConfigGenerationResponse": {
        "properties": {
          "generation": {
            "$ref": "#/components/schemas/ttab.distribution.ConfigGeneration"
          },
          "unchanged": {
            "description": "Unchanged is true if KnownId matched the active generation and OnlyChanged was set.",
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetAllActiveSchemasRequest": {
        "properties": {
          "known": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Known schema versions that the client already has. Optional.",
            "type": "object"
          },
          "only_changed": {
            "description": "OnlyChanged only returns the schemas that have been changed.",
            "type": "boolean"
          },
          "wait_seconds": {
            "description": "WaitSeconds is the maximum number of seconds to wait for changes, defaults to 10 seconds. Optional.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetAllActiveSchemasResponse": {
        "properties": {
          "removed": {
            "description": "Removed schemas.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "schemas": {
            "description": "Schemas that currently are active.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.Schema"
            },
            "type": "array"
          },
          "unchanged": {
            "description": "Unchanged is set to true if no changes were done compared to known schema versions.",
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetArchivedDocumentRequest": {
        "properties": {
          "uuid": {
            "description": "UUID of the document.",
            "type": "string"
          },
          "version": {
            "description": "Version to get a URL for.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetArchivedDocumentResponse": {
        "properties": {
          "content_url": {
            "description": "ContentURL is a presigned GET URL for the canonical document JSON.",
            "type": "string"
          },
          "hash": {
            "description": "Hash is the hex-encoded sha256 of the canonical document body.",
            "type": "string"
          },
          "signature": {
            "description": "Signature covers the document body, for end-to-end verification.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetDocumentRequest": {
        "properties": {
          "disable_rendition_signing": {
            "description": "DisableRenditionSigning serves the document with its stored, unsigned rendition URLs. See GetNewDocumentsRequest.disable_rendition_signing.",
            "type": "boolean"
          },
          "uuid": {
            "description": "UUID of the document to get.",
            "type": "string"
          },
          "version": {
            "description": "Version to get, or 0 for the latest version.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetDocumentResponse": {
        "properties": {
          "document": {
            "$ref": "#/components/schemas/newsdoc.Document"
          },
          "version": {
            "description": "Version that was returned.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetDocumentTypesRequest": {
        "type": "object"
      },
      "ttab.distribution.GetDocumentTypesResponse": {
        "properties": {
          "types": {
            "description": "Types that have been defined in the schema.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetNewDocumentsRequest": {
        "properties": {
          "after": {
            "description": "After returns new documents after the given event ID. A negative value is an offset from the newest event instead: -N returns the last N events (so at head 20, -5 yields events 16 through 20). The count is resolved against the log head at call time and capped at the same page size as a positive read. An offset reaching past the start of the log is clamped to the beginning.",
            "type": "integer"
          },
          "disable_rendition_signing": {
            "description": "DisableRenditionSigning serves documents with their stored, unsigned rendition URLs instead of signing rendition links for the caller's audience. Intended for internal consumers that re-sign at their own delivery time; external consumers should leave it unset.",
            "type": "boolean"
          },
          "load_documents": {
            "description": "LoadDocuments should be set to true if you want the full documents in the response. If subset is used it will override load_documents.",
            "type": "boolean"
          },
          "subset": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ttab.distribution.Subsets"
            },
            "description": "Subset returns a subset of the documents as specified by a map of newsdoc value extractors keyed by the types that they should be applied to.",
            "type": "object"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetNewDocumentsResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.DocumentItem"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetSchemaRequest": {
        "properties": {
          "name": {
            "description": "Name of the schema to get.",
            "type": "string"
          },
          "version": {
            "description": "Version of the schema to get, optional. The currently active version of the schema will be returned if no version is specified.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetSchemaResponse": {
        "properties": {
          "spec": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetSyncStatusRequest": {
        "type": "object"
      },
      "ttab.distribution.GetSyncStatusResponse": {
        "properties": {
          "caught_up": {
            "description": "CaughtUp is true if the sync worker had caught up with the head of the repository eventlog when it last stored its position.",
            "type": "boolean"
          },
          "current": {
            "description": "Current is the state the sync worker most recently reported, either \"running\" or \"paused\". Empty if the worker has never reported a state.",
            "type": "string"
          },
          "desired": {
            "description": "Desired is the state the sync worker should be in, either \"running\" or \"paused\".",
            "type": "string"
          },
          "position": {
            "description": "Position is the repository eventlog ID that the sync worker has processed up to.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetTypeConfigurationRequest": {
        "properties": {
          "type": {
            "description": "Type to get configuration for.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.GetTypeConfigurationResponse": {
        "properties": {
          "configuration": {
            "$ref": "#/components/schemas/ttab.distribution.TypeConfiguration"
          }
        },
        "type": "object"
      },
      "ttab.distribution.LabelExpression": {
        "properties": {
          "expression": {
            "description": "Expression is a newsdoc value extraction expression.",
            "type": "string"
          },
          "template": {
            "description": "Template is the template that turns the extracted values into a label.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListArchiveChunksRequest": {
        "properties": {
          "after_chunk_id": {
            "description": "AfterChunkID lists chunks after the given chunk ID; 0 to start.",
            "type": "integer"
          },
          "page_size": {
            "description": "PageSize defaults to 100.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListArchiveChunksResponse": {
        "properties": {
          "chunks": {
            "description": "Chunks in this page, in ascending chunk-ID order.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ArchiveChunk"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListArchivedDocumentsRequest": {
        "properties": {
          "cursor": {
            "description": "Cursor from a previous response; empty to start a new drain.",
            "type": "string"
          },
          "page_size": {
            "description": "PageSize defaults to 1000.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListArchivedDocumentsResponse": {
        "properties": {
          "documents": {
            "description": "Documents in this page.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ArchivedDocument"
            },
            "type": "array"
          },
          "next_cursor": {
            "description": "NextCursor is empty when the catalog has been exhausted.",
            "type": "string"
          },
          "watermark_event_id": {
            "description": "WatermarkEventID is the last archived event ID as of the start of the drain. A consumer that has drained the catalog should tail Content.GetNewDocuments from this ID: everything up to it is covered by the catalog, everything after it by the tail.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListConfigGenerationsRequest": {
        "properties": {
          "before": {
            "description": "Before is the highest generation ID to return; defaults to the latest. Use the smallest returned ID to paginate further into the past.",
            "type": "integer"
          },
          "page_size": {
            "description": "PageSize defaults to 50, max 200.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.distribution.ListConfigGenerationsResponse": {
        "properties": {
          "generations": {
            "description": "Generations without schemas or type configurations populated.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ConfigGeneration"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.RegisterConfigGenerationRequest": {
        "properties": {
          "activate": {
            "description": "Activate the new generation immediately. Defaults to false; callers typically register first and activate as a separate step so they can inspect the diff first.",
            "type": "boolean"
          },
          "description": {
            "description": "Description is an optional human-readable tag for the new generation.",
            "type": "string"
          },
          "schemas": {
            "description": "Schemas the generation should contain. Order is preserved.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ConfigGenerationSchema"
            },
            "type": "array"
          },
          "types": {
            "description": "Types the generation should contain. Order is preserved.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.ConfigGenerationType"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.RegisterConfigGenerationResponse": {
        "properties": {
          "generation": {
            "$ref": "#/components/schemas/ttab.distribution.ConfigGeneration"
          }
        },
        "type": "object"
      },
      "ttab.distribution.Schema": {
        "properties": {
          "name": {
            "type": "string"
          },
          "spec": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.SetSyncStateRequest": {
        "properties": {
          "desired": {
            "description": "Desired state of the sync worker, either \"running\" or \"paused\".",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.distribution.SetSyncStateResponse": {
        "type": "object"
      },
      "ttab.distribution.Subsets": {
        "properties": {
          "expressions": {
            "description": "Expressions to use to extract document contents.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.TypeConfiguration": {
        "properties": {
          "bounded_collection": {
            "description": "Set to true if this is a collection of documents that are bounded (limited in size). Bounded collections can be fetched by type and language in one go.",
            "type": "boolean"
          },
          "label_expressions": {
            "description": "LabelExpressions are used to extract labels from documents.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.LabelExpression"
            },
            "type": "array"
          },
          "time_expressions": {
            "description": "TimeExpressions are used for extracting time ranges from documents.",
            "items": {
              "$ref": "#/components/schemas/ttab.distribution.TypeTimeExpression"
            },
            "type": "array"
          },
          "transform_script": {
            "description": "TransformScript is the transformation script for this document type.",
            "type": "string"
          },
          "variants": {
            "description": "Variants are the allowed variants for the document type.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.distribution.TypeTimeExpression": {
        "properties": {
          "expression": {
            "description": "Expression is a newsdoc value extraction expression.",
            "type": "string"
          },
          "layout": {
            "description": "Layout is the time/date format to use when parsing. Optional, defaults to RFC3339 or ISO 8601 for values annotated as dates.",
            "type": "string"
          },
          "timezone": {
            "description": "Timezone is the timezone the time should be parsed in. Optional, most timestamps should include timezone information, if they don't, parsing will fall back to the default timezone that the repository has been configured with.",
            "type": "string"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
