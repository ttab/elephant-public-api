    "/twirp/ttab.distribution.Configuration/ListConfigGenerations": {
      "post": {
        "description": "ListConfigGenerations lists historical generations, most recent first.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ttab.distribution.ListConfigGenerationsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ttab.distribution.ListConfigGenerationsResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "ListConfigGenerations",
        "tags": [
          "Configuration"
        ]
      }
    },
    "/twirp/ttab.distribution.Configuration/RegisterConfigGeneration": {
      "post": {
        "description": "RegisterConfigGeneration registers a complete configuration set (schemas + type configurations) as a new generation. Existing schema versions can be re-used by name and version without re-supplying the spec; if the spec is supplied for an existing version it must match the stored one. Returns the new generation ID.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ttab.distribution.RegisterConfigGenerationRequest"
              }
            }
          }
